# Remote Job Server Configuration Example
# このファイルを .env にコピーして設定を編集してください

# API認証キー（本番環境用の強力なキーを生成してください）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secure-api-key-here

# データベースURL
DATABASE_URL=sqlite:///./data/jobs.db

# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS許可オリジン（カンマ区切りで複数指定可能）
ALLOWED_ORIGINS=http://100.100.30.35:35000,http://127.0.0.1:35000
