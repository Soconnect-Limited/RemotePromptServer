# Remote Job Server Configuration Example
# このファイルを .env にコピーして設定を編集してください

# API認証キー（本番環境用の強力なキーを生成してください）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secure-api-key-here

# データベースURL
DATABASE_URL=sqlite:///./data/jobs.db

# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS許可オリジン（カンマ区切りで複数指定可能）
ALLOWED_ORIGINS=http://100.100.30.35:35000,http://127.0.0.1:35000

# ========== SSL/TLS Certificate Configuration ==========

# SSL Mode: "commercial", "self_signed", or "auto"
# - commercial: Let's Encrypt等の商用証明書を使用
# - self_signed: 自己署名証明書を使用（ローカルネットワーク向け）
# - auto: 商用証明書があれば使用、なければ自己署名にフォールバック
SSL_MODE=auto

# Auto mode fallback (セキュリティのため明示的なオプトインが必要)
# true にすると、商用証明書がない場合に自己署名にフォールバック
SSL_AUTO_FALLBACK_ENABLED=false

# 自己署名証明書の保存パス
SSL_CERT_PATH=./certs/self_signed/server.crt
SSL_KEY_PATH=./certs/self_signed/server.key

# 証明書の自動生成（self_signed mode時）
SSL_AUTO_GENERATE=true

# サーバーホスト名（証明書のCN）
# 自分の環境に合わせて変更してください
SERVER_HOSTNAME=your-server-hostname

# SANに含めるIPアドレス（カンマ区切り）
# 例: ローカルLAN IP, Tailscale VPN IP, localhost
# 自分の環境に合わせて変更してください
SERVER_SAN_IPS=192.168.x.x,100.x.x.x,127.0.0.1

# サーバーポート
SERVER_PORT=8443

# 商用証明書のパス（Let's Encrypt等）
COMMERCIAL_CERT_PATH=./certs/config/live/remoteprompt.soconnect.co.jp/fullchain.pem
COMMERCIAL_KEY_PATH=./certs/config/live/remoteprompt.soconnect.co.jp/privkey.pem

# ========== Bonjour (mDNS/DNS-SD) Configuration ==========

# Bonjourサービス公開を有効化（ローカルネットワーク自動検出）
BONJOUR_ENABLED=true

# iOSクライアントに表示されるサーバー名
BONJOUR_SERVICE_NAME=RemotePrompt Server
